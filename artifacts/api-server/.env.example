# ─── Arcpay API Server — environment variables ──────────────────────────────
#
# PORT (required)
#   The port the Express server listens on.
#   Render, Railway, and Heroku inject this automatically — you usually
#   don't need to set it manually on those platforms.
#
PORT=8080

# SESSION_SECRET (optional — reserved for future auth use)
#   A long random string used to sign session cookies.
#   Not actively used by any route yet, but good to set now.
#
# SESSION_SECRET=change-me-to-a-long-random-string
