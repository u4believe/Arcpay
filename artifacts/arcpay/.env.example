# ─── Arcpay Frontend — environment variables ────────────────────────────────
#
# VITE_API_URL
#   Full origin of your deployed API server (no trailing slash).
#   Leave this UNSET in local development — Vite's dev proxy handles /api/*
#   automatically by forwarding to localhost:8080.
#
#   Example (Render):
#     VITE_API_URL=https://arcpay-api.onrender.com
#
#   Example (Railway):
#     VITE_API_URL=https://arcpay-api.up.railway.app
#
# VITE_API_URL=https://your-api-server.onrender.com
